# 양산형 SEO 서버 환경변수 — 복사해서 .env 로 사용 (.env 는 gitignore 됨)

# --- 서버 ---
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8765
ADMIN_RELOAD=0
ADMIN_PASSWORD=            # 비우면 로컬 오픈, 운영에선 반드시 설정

# --- 브랜드/콘텐츠 ---
SEO_BRAND_NAME=운전면허플러스
SEO_QUALITY_MIN_TEXT_CHARS=1500
SEO_QUALITY_MAX_TEXT_CHARS=6500
SEO_QUALITY_MAX_ATTEMPTS=2

# --- DB (도커 볼륨 등으로 옮길 때) ---
# SEO_DB_PATH=/data/admin.db

# --- 워커 ---
WORKER_POLL_INTERVAL=3

# --- 공개 API / 데이터 수신 ---
PUBLIC_API_ORIGINS=*               # 운영: https://academy.drivingplus.me 등으로 제한
INGEST_TOKEN=                      # 학원데이터 POST 보호(설정 시 x-ingest-token 필요)

# --- 이미지 자동수집(선택) ---
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# --- 색인(선택, 설정에서 UI로도 등록 가능) ---
# google_sa_json / indexing_url_template 은 app_settings(DB)에 저장
